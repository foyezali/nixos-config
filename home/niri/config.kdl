// Minimal niri config — ThinkPad P1 Gen 3
// Only what's needed to boot and work

// ── Input ─────────────────────────────────────────────────────────────────────
input {
    keyboard {
        xkb {
            options "caps:escape,compose:menu"
        }
    }
    touchpad {
        tap
        dwt
    }
}

// ── Layout ─────────────────────────────────────────────────────────────────────
layout {
    gaps 16
}

// ── Bindings ──────────────────────────────────────────────────────────────────
binds {
    // Terminal — alacritty
    Mod+Return    { spawn "alacritty"; }

    // App launcher
    Mod+D         { spawn "wofi"; }

    // Window management
    Mod+Q         { close-window; }
    Mod+Space     { toggle-window-floating; }
    Mod+F         { fullscreen-window; }

    // Focus columns and windows
    Mod+Left      { focus-column-left; }
    Mod+Right     { focus-column-right; }
    Mod+Down      { focus-window-down; }
    Mod+Up        { focus-window-up; }

    // Workspaces
    Mod+1         { focus-workspace "0"; }
    Mod+2         { focus-workspace "1"; }
    Mod+3         { focus-workspace "2"; }
    Mod+4         { focus-workspace "3"; }
    Mod+5         { focus-workspace "4"; }
    Mod+6         { focus-workspace "5"; }

    // Screenshot
    Mod+S         { spawn "grim"; "-g"; }

    // Lock
    Mod+L         { spawn "waylock"; "-f"; }
}

// ── Output ─────────────────────────────────────────────────────────────────────
output "eDP-1" {
    mode "1920x1080@60"
}
