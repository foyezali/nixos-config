// Niri config — ThinkPad P1 Gen 3
// Docs: https://niri-wm.github.io/niri/Configuration:-Introduction

// ── Workspaces ────────────────────────────────────────────────────────────────
// niri starts with 1 workspace by default — no explicit workspace declaration needed
// App-specific workspace rules:
window-rule {
    match app-id="firefox"
    spawn-at-workspace 0
}
window-rule {
    match app-id="thunderbird"
    spawn-at-workspace 1
}

// ── Layout ─────────────────────────────────────────────────────────────────────
layout {
    spacing 10

    floating window {
        // Reasonable floating window size in pixels (was: 60x60 which is microscopic)
        dimensions 1152 648
        position center
    }
}

// ── Input ─────────────────────────────────────────────────────────────────────
// Cursor follows focus but doesn't warp to every click
focus-under-mouse false
warp cursor-on-focus true

// ── Keyboard ──────────────────────────────────────────────────────────────────
input {
    keyboard {
        xkb {
            options "caps:escape,compose:menu,numlock:on"
        }
    }
}

// ── Touchpad ──────────────────────────────────────────────────────────────────
input {
    touchpad {
        tap
        disable-while-typing
    }
}

// ── Bindings ──────────────────────────────────────────────────────────────────
binds {
    // ── Focus output (monitor) ──
    Mod+Left  { focus-output left; }
    Mod+Right { focus-output right; }
    Mod+Up    { focus-output up; }
    Mod+Down  { focus-output down; }

    // ── Move window between outputs ──
    Mod+Shift+Left  { move-window-to-output left; }
    Mod+Shift+Right { move-window-to-output right; }
    Mod+Shift+Up    { move-window-to-output up; }
    Mod+Shift+Down  { move-window-to-output down; }

    // ── Switch workspaces (1-indexed internally, 0-indexed in config) ──
    Mod+1 { focus-workspace 0; }
    Mod+2 { focus-workspace 1; }
    Mod+3 { focus-workspace 2; }
    Mod+4 { focus-workspace 3; }
    Mod+5 { focus-workspace 4; }
    Mod+6 { focus-workspace 5; }

    // ── Move window to workspace ──
    Mod+Shift+1 { move-window-to-workspace 0; }
    Mod+Shift+2 { move-window-to-workspace 1; }
    Mod+Shift+3 { move-window-to-workspace 2; }
    Mod+Shift+4 { move-window-to-workspace 3; }
    Mod+Shift+5 { move-window-to-workspace 4; }
    Mod+Shift+6 { move-window-to-workspace 5; }

    // ── Floating / fullscreen ──
    Mod+Space     { toggle-windowed-floating; }
    Mod+F         { fullscreen; }
    Mod+Shift+F   { toggle-maximize-to-edges; }

    // ── Close window ──
    Mod+Q         { close; }

    // ── Spawn terminal ──
    Mod+Return    { spawn "alacritty"; }

    // ── App launcher ──
    Mod+D         { spawn "wofi"; }

    // ── Screenshot ( grim = full screen, grim -g = selection ) ──
    Mod+S         { spawn "grim"; }
    Mod+Shift+S   { spawn "grim"; "-g"; }

    // ── Lock screen ──
    Mod+L         { spawn "waylock"; "-f"; }
}

// ── Window rules ───────────────────────────────────────────────────────────────
window-rule {
    match app-id="pavucontrol"
    open-floating true
}
window-rule {
    match app-id="blueman-manager"
    open-floating true
}
window-rule {
    match app-id="nm-connection-editor"
    open-floating true
}

// ── Looks ─────────────────────────────────────────────────────────────────────
cursor {
    hide-when-typing true
    active-color "#cdd6f4"
    inactive-color "#cba6f7"
}

// ── Misc ───────────────────────────────────────────────────────────────────────
resize-area 32
show-hidden-in-active-workspace true

// ── Output ─────────────────────────────────────────────────────────────────────
// ThinkPad P1 Gen 3 internal display
output "eDP-1" {
    mode "1920x1080@60"
    position x=0 y=0
}
